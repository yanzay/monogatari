#!/usr/bin/env bash
# Monogatari pre-commit hook.
#
# Bumps CACHE_VERSION inside sw.js whenever any of the front-end files
# (index.html, js/, css/, stories/, audio/, data/) is part of the commit,
# so existing visitors immediately see the "update available" toast next
# time they open the page.
#
# Install:
#   git config core.hooksPath .githooks
#
# (also run automatically by `make hooks` or by anyone who follows the
# README setup instructions).

set -euo pipefail

watched_re='^(index\.html|sw\.js|js/|css/|stories/|audio/|data/)'
if ! git diff --cached --name-only | grep -qE "$watched_re"; then
  exit 0
fi

# Compose a fresh version label: v1-YYYY-MM-DD-HHMMSS
new_version="v1-$(date -u +%Y-%m-%d-%H%M%S)"
file="sw.js"

if [ ! -f "$file" ]; then
  exit 0
fi

# Replace the existing CACHE_VERSION line with the new value.
# Works on macOS BSD sed and GNU sed (in-place edit with .bak then remove).
sed -i.bak -E "s|^const CACHE_VERSION[[:space:]]*=[[:space:]]*'[^']*';|const CACHE_VERSION = '${new_version}';|" "$file"
rm -f "${file}.bak"

git add "$file"
echo "[pre-commit] Bumped CACHE_VERSION → ${new_version}"

# ── Run validation test suites if any data/, stories/, or pipeline/ file is staged ──
test_re='^(data/|stories/|pipeline/)'
if git diff --cached --name-only | grep -qE "$test_re"; then
  # Use the venv's python if available, otherwise fall back to system python3
  if [ -x ".venv/bin/python3" ]; then
    PYTHON=".venv/bin/python3"
  else
    PYTHON="python3"
  fi

  echo "[pre-commit] Running pipeline test suites…"

  if ! "$PYTHON" pipeline/test_validate.py > /tmp/monogatari_test_validate.log 2>&1; then
    echo "✗ pipeline/test_validate.py FAILED. See /tmp/monogatari_test_validate.log"
    tail -20 /tmp/monogatari_test_validate.log
    exit 1
  fi

  if ! "$PYTHON" -m pytest pipeline/tests -q --tb=line > /tmp/monogatari_pytest.log 2>&1; then
    echo "✗ pipeline/tests pytest suite FAILED. See /tmp/monogatari_pytest.log"
    tail -30 /tmp/monogatari_pytest.log
    exit 1
  fi

  echo "[pre-commit] ✓ all tests pass"
fi
