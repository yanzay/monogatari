{
  "story_id": 21,
  "title": {
    "jp": "雪の道",
    "en": "The Snowy Road"
  },
  "sentences": [
    {
      "jp": "寒い夜、外は雪です。",
      "en": "Cold night, outside is snow."
    },
    {
      "jp": "私は、一人で帰ります。",
      "en": "I walk home alone."
    },
    {
      "jp": "道は静かです。",
      "en": "The road is quiet."
    },
    {
      "jp": "道に、雪があります。",
      "en": "There is snow on the road."
    },
    {
      "jp": "月は、空にあります。",
      "en": "The moon is in the sky."
    },
    {
      "jp": "月は大きいです。",
      "en": "The moon is big."
    },
    {
      "jp": "雪は小さいです。",
      "en": "The snow is small."
    },
    {
      "jp": "雪の道、月の空。",
      "en": "A snowy road, the moon's sky."
    },
    {
      "jp": "一人の夜、私は名前を書きます。",
      "en": "Alone at night, I write a name."
    },
    {
      "jp": "道の角は静かです。",
      "en": "The road's corner is quiet."
    },
    {
      "jp": "友達は来ません。",
      "en": "My friend does not come."
    },
    {
      "jp": "「元気ですか」と思います。",
      "en": "'Are you well?' I think."
    },
    {
      "jp": "友達の母は元気です。",
      "en": "My friend's mother is well."
    }
  ]
}
