{
  "story_id": 46,
  "title": {
    "jp": "寒くない朝",
    "en": "A Not-Cold Morning"
  },
  "sentences": [
    {
      "jp": "春の朝です。",
      "en": "It is a spring morning."
    },
    {
      "jp": "朝は寒くないです。",
      "en": "The morning is not cold."
    },
    {
      "jp": "空気は明るいです。",
      "en": "The air is bright."
    },
    {
      "jp": "春の光は温かいです。",
      "en": "The spring light is warm."
    },
    {
      "jp": "私は窓のそばに立ちます。",
      "en": "I stand by the window."
    },
    {
      "jp": "鳥が空にいます。",
      "en": "A bird is in the sky."
    },
    {
      "jp": "部屋に花があります。",
      "en": "There are flowers in the room."
    },
    {
      "jp": "花は美しいです。",
      "en": "The flowers are beautiful."
    },
    {
      "jp": "冬の朝は寒いです。",
      "en": "Winter mornings are cold."
    },
    {
      "jp": "でも、春の朝は寒くないです。",
      "en": "But spring mornings are not cold."
    },
    {
      "jp": "私は仕事を始めます。",
      "en": "I begin the work."
    },
    {
      "jp": "春が来ますから、私は待ちません。",
      "en": "Because spring is coming, I do not wait."
    },
    {
      "jp": "春は美しいですか。",
      "en": "Is spring beautiful?"
    },
    {
      "jp": "春は美しいです。",
      "en": "Spring is beautiful."
    },
    {
      "jp": "これは明るい朝、温かい光です。",
      "en": "This is a bright morning, warm light."
    }
  ]
}
