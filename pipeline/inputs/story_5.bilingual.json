{
  "story_id": 5,
  "title": {
    "jp": "朝の散歩",
    "en": "A Morning Walk"
  },
  "sentences": [
    {
      "jp": "朝、私は公園を歩きます。",
      "en": "Morning — I walk through the park."
    },
    {
      "jp": "木と花は静かです。",
      "en": "The trees and flowers are quiet."
    },
    {
      "jp": "そして、私は帰ります。",
      "en": "And then I head home."
    },
    {
      "jp": "ドアを見ます。",
      "en": "I see the door."
    },
    {
      "jp": "ドアの外は雨です。",
      "en": "Outside the door, it's raining."
    },
    {
      "jp": "そして、風です。",
      "en": "And then — wind."
    },
    {
      "jp": "風と雨、いい朝です。",
      "en": "Wind and rain — a good morning."
    }
  ]
}
