  "story_id": 3,
  "title": {
    "jp": "朝ごはん",
    "en": "Breakfast"
  },
  "sentences": [
    {
      "jp": "朝、雨です。",
      "en": "Morning — and rain."
    },
    {
      "jp": "卵は温かいです。",
      "en": "The eggs are warm."
    },
    {
      "jp": "朝ごはんは卵とお茶です。",
      "en": "Breakfast is eggs and tea."
    },
    {
      "jp": "卵を食べます。",
      "en": "I eat the eggs."
    },
    {
      "jp": "お茶も温かいです。",
      "en": "The tea is warm, too."
    },
    {
      "jp": "朝ごはんを食べます。",
      "en": "I eat my breakfast."
    },
    {
      "jp": "窓から外を見ます。",
      "en": "I look outside through the window."
    },
    {
      "jp": "雨の外と静かな朝、いい気分です。",
      "en": "The rain-outside and the quiet morning — a good feeling."
    }
  ]
}
