{
  "story_id": 2,
  "title": {
    "jp": "夕方の公園",
    "en": "The Evening Park"
  },
  "sentences": [
    {
      "jp": "夕方、私と友達は公園を歩きます。",
      "en": "Evening — my friend and I walk through the park."
    },
    {
      "jp": "木は濡れています。",
      "en": "The trees are wet."
    },
    {
      "jp": "公園は静かです。",
      "en": "The park is quiet."
    },
    {
      "jp": "友達もお茶を飲みます。",
      "en": "My friend drinks tea, too."
    },
    {
      "jp": "お茶は温かいです。",
      "en": "The tea is warm."
    },
    {
      "jp": "私もいい気分です。",
      "en": "I feel good, too."
    },
    {
      "jp": "夕方の公園を歩きます。",
      "en": "We walk through the evening park."
    }
  ]
}
