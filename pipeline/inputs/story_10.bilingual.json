{
  "story_id": 10,
  "title": {
    "jp": "友達からの手紙",
    "en": "A Letter from a Friend"
  },
  "sentences": [
    {
      "jp": "朝、風が来ます。",
      "en": "Morning — the wind comes."
    },
    {
      "jp": "友達から手紙が来ます。",
      "en": "A letter comes from my friend."
    },
    {
      "jp": "私は手紙を読みます。",
      "en": "I read the letter."
    },
    {
      "jp": "朝は静かです。",
      "en": "The morning is quiet."
    },
    {
      "jp": "私は友達の朝を待ちます。",
      "en": "I wait — for my friend's morning."
    },
    {
      "jp": "そして、友達も寝ます。",
      "en": "And the friend, too, sleeps."
    },
    {
      "jp": "友達からの手紙、私は待ちます。",
      "en": "A letter from my friend — I wait."
    },
    {
      "jp": "犬は家にいます。",
      "en": "The dog is at home."
    },
    {
      "jp": "椅子に座ります。",
      "en": "I sit on a chair."
    }
  ]
}
