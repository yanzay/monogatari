{
  "story_id": 32,
  "title": {
    "jp": "冬の朝ごはん",
    "en": "Winter Breakfast"
  },
  "sentences": [
    {
      "jp": "冬の朝です。",
      "en": "It is a winter morning."
    },
    {
      "jp": "寒い朝です。",
      "en": "It is a cold morning."
    },
    {
      "jp": "私は卵を食べます。",
      "en": "I eat an egg."
    },
    {
      "jp": "カップのお茶も飲みます。",
      "en": "I also drink a cup of tea."
    },
    {
      "jp": "父から電話が来ます。",
      "en": "A phone call comes from father."
    },
    {
      "jp": "「寒い朝ごはんですね」と言います。",
      "en": "\"Cold morning breakfast, isn't it,\" he says."
    },
    {
      "jp": "私の名前を言います。",
      "en": "He says my name."
    },
    {
      "jp": "「元気ですか」と言います。",
      "en": "\"Are you well?\" he says."
    },
    {
      "jp": "家族について、名前を言います。",
      "en": "About family, he says a name."
    },
    {
      "jp": "そして出ます。",
      "en": "He leaves."
    },
    {
      "jp": "温かいお茶を飲みます。",
      "en": "I drink the warm tea."
    },
    {
      "jp": "嬉しい秋と冬です。",
      "en": "A joyful autumn and winter."
    }
  ]
}
