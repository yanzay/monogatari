{
  "story_id": 40,
  "title": {
    "jp": "手紙の返事",
    "en": "The Letter's Reply"
  },
  "sentences": [
    {
      "jp": "夕方です。",
      "en": "It is evening."
    },
    {
      "jp": "私は机にいます。",
      "en": "I am at the desk."
    },
    {
      "jp": "昨日、雨が降りました。",
      "en": "Yesterday, rain fell."
    },
    {
      "jp": "人は傘を渡しました。",
      "en": "The person handed me the umbrella."
    },
    {
      "jp": "私は嬉しいです。",
      "en": "I am happy."
    },
    {
      "jp": "私は返事を書きたいです。",
      "en": "I want to write a reply."
    },
    {
      "jp": "痛い心の言葉は小さくて静かです。",
      "en": "The words of my painful heart are small and quiet."
    },
    {
      "jp": "私は「嬉しい」と書きました。",
      "en": "I wrote, \"happy.\""
    },
    {
      "jp": "私は「優しい人」と書きました。",
      "en": "I wrote, \"a kind person.\""
    },
    {
      "jp": "でも、言葉は小さいです。",
      "en": "But the words are small."
    },
    {
      "jp": "私は返事を思います。",
      "en": "I think about the reply."
    },
    {
      "jp": "でも、好きな人の名前は思い出です。",
      "en": "But the loved person's name is a memory."
    },
    {
      "jp": "静かな夕方の強い言葉です。",
      "en": "A quiet evening's strong words."
    },
    {
      "jp": "犬は池のそばを走ります。",
      "en": "The dog runs by the pond."
    },
    {
      "jp": "私は朝の散歩を始めます。",
      "en": "I begin my morning walk."
    },
    {
      "jp": "祖母はカップを持ちます。",
      "en": "Grandmother holds a cup."
    },
    {
      "jp": "私は店へ行きます。",
      "en": "I go to the shop."
    },
    {
      "jp": "朝の光は明るいです。",
      "en": "The morning light is bright."
    }
  ]
}
