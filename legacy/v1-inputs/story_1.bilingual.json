  "title": {
    "jp": "雨",
    "en": "Rain"
  },
  "sentences": [
    {
      "jp": "今朝は雨です。",
      "en": "This morning, it is raining."
    },
    {
      "jp": "私は窓から外を見ます。",
      "en": "I look outside through the window."
    },
    {
      "jp": "木が濡れています。",
      "en": "The tree is wet."
    },
    {
      "jp": "私はお茶を飲みます。",
      "en": "I drink the tea."
    },
    {
      "jp": "雨は静かです。",
      "en": "The rain is quiet."
    },
    {
      "jp": "お茶は温かいです。",
      "en": "The tea is warm."
    },
    {
      "jp": "今朝はいい気分です。",
      "en": "This morning feels good."
    }
  ]
}
