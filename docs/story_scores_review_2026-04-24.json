  "scale": {
    "version": "fresh-review-2",
    "date": "2026-04-24",
    "context": "Independent re-review of all 67 stories in pipeline/inputs/, using a comprehensive 6-axis rubric covering literacy, interest, engagement, and craft.",
    "scoring": {
      "per_axis_max": 5,
      "per_axis_anchors": {
        "5": "Exemplary; could ship as-is to a published graded reader.",
        "4": "Strong; minor weakness only.",
        "3": "Competent; clear but ordinary or partially compromised.",
        "2": "Weak; visible structural or pedagogical seams.",
        "1": "Poor; reads as a drill, not as a story."
      },
      "total_max": 30,
      "tier_bands": {
        "S (excellent)": "26-30",
        "A (strong)": "22-25",
        "B (solid)": "18-21",
        "C (uneven)": "14-17",
        "D (weak)": "0-13"
      }
    },
    "axes": [
      {
        "id": "literacy",
        "label": "Literacy / linguistic quality",
        "what_it_measures": "Grammatical correctness, particle accuracy, register consistency, idiomatic phrasing, dictionary-clean vocabulary use. The Japanese should sound like Japanese, not translated English.",
        "what_lowers_it": "Awkward calques, unnatural collocations, misuses (e.g. 山 for mountain-as-name without context), particle drift, register mismatches, stiff repetition of the same predicate."
      },
      {
        "id": "comprehensibility",
        "label": "Comprehensibility for the level",
        "what_it_measures": "How easily an A1/A2 learner can decode the text on first read at the expected grammar/vocab band. Sentence length, syntactic depth, and clarity of referent.",
        "what_lowers_it": "Pronoun ambiguity, abrupt new vocabulary clusters, dense sub-clauses, sentences that require external context to parse."
      },
      {
        "id": "scene_coherence",
        "label": "Scene coherence",
        "what_it_measures": "Whether the story stays inside one place / time / mood. A coherent piece holds the reader inside a single frame; an incoherent one drifts between unrelated images.",
        "what_lowers_it": "Tail sentences that drop the current scene to mention an unrelated character/location, time-jumps without scaffolding, paragraphs that read like separate pieces glued together."
      },
      {
        "id": "narrative_shape",
        "label": "Narrative shape",
        "what_it_measures": "Presence of a discernible arc, turn, or payoff. Even a 6-sentence mood piece can have shape (setup -> turn -> rest).",
        "what_lowers_it": "List-like progression, no movement of feeling or situation, a closing sentence that merely re-lists the title's nouns."
      },
      {
        "id": "engagement_emotion",
        "label": "Engagement / emotional pull",
        "what_it_measures": "Memorability, mood, affective traction; whether the reader carries an image or feeling out of the piece.",
        "what_lowers_it": "Flat description, missing stakes, generic concepts (\"a quiet morning\") with no anchoring detail, sentimental repetition without earned emotion."
      },
      {
        "id": "economy_density",
        "label": "Economy / density",
        "what_it_measures": "Each sentence pulling weight; absence of visible reinforcement filler or pedagogical tails. Closely related to whether the piece feels authored or generated.",
        "what_lowers_it": "Tail sentences that exist only to repeat a vocab word, sudden roster of unrelated nouns at the end, padded triplet closings (X, Y, Zです) that re-package what was already shown."
      }
    ],
    "global_observations_before_scoring": [
      "The library is consistently strong on literacy: particles, basic predicates, and te-form chaining are accurate throughout.",
      "The recurring weakness is reinforcement tails. Many otherwise-shapely stories lose 1-3 economy points to a closing cluster of unrelated sentences (a brother appears, a bell rings, a parking lot is mentioned) that satisfy vocab/grammar reuse but break scene coherence.",
      "Question-driven and dialogue-driven stories (47, 50, 61, 62) carry more narrative energy than purely descriptive ones.",
      "Stories that build on a single sustained image (1, 30, 36, 46) and resist late add-ons are the strongest.",
      "The mid-30s through high-50s contain the most pedagogical-feeling tails because the cadence work in Phase 6 wove reinforcement there."
    ]
  },
